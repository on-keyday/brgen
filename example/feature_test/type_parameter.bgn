# Phase 1: type parameter declaration and usage
# Checks:
#   - `format Foo[T]` parses
#   - `format Bar[T, U]` parses (multiple parameters)
#   - type parameter idents land in Format.type_parameters and in the body scope
#   - usage is IdentUsage::define_type_parameter
#   - `x :T` resolves T via scope lookup
#   - `f :Foo[u8]` parses as GenericType { base_type: Foo, type_arguments: [u8] }
# Not yet covered (later phases):
#   - instantiation / monomorphization
#   - type checking of type arguments vs parameter count

format Foo[T]:
    x :T
    y :u16

format Bar[T, U]:
    a :T
    b :U

format Plain:
    z :u8

format UsesFoo:
    f :Foo[u8]
    g :Bar[u16, u32]
    x :Foo[u32]
    z :Foo[Plain]
    b :Bar[Plain,u64]
    b2 :Bar[u64,Plain]
    match z.x.z:
        32 => field :u8
    match b.a.z:
        64 => field :u64


format Vector[T]:
    len :u16
    len % sizeof(T) == 0
    data :[len / sizeof(T)]T

format Place[T]:
    place :[sizeof(T)]u8

format UsesVector:
    v :Vector[u8]
    match v.data.length:
        0 => field :u8
        ..:
            x ::= v.data[0] 
            x == 1

    place :Place[u32]

format Vector2[T]:
    length :u16
    length % sizeof(T) == 0
    length >= 0 && length <= 0xfffe
    data :[length / sizeof(T)]T

format CipherSuites:
    cipher_suites :Vector2[u16]
    cipher_suites.length >= 2

